# Copy to .env and fill values for your target GCP project
GCP_PROJECT_ID=your-gcp-project-id
BQ_DATASET_RAW=raw
BQ_DATASET_ANALYTICS=raw
GOOGLE_APPLICATION_CREDENTIALS=/workspace/secrets/cloud_key.json
KESTRA_POSTGRES_PASSWORD=your-kestra-postgres-password
KESTRA_BASIC_AUTH_USERNAME=admin@kestra.io
KESTRA_BASIC_AUTH_PASSWORD=your-kestra-admin-password
